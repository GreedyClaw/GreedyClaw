# GreedyClaw Configuration
# Copy to ~/.greedyclaw/.env and fill in your keys

# ── Gateway Auth ─────────────────────────────────────────────
GREEDYCLAW_AUTH_TOKEN=change_me_to_random_hex_token

# ── Binance ──────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here

# ── MT5 Bridge (Forex, Gold, Indices) ────────────────────────
# MT5_BRIDGE_URL=http://127.0.0.1:7879

# ── CCXT Bridge (Bybit, OKX, Kraken, 100+ exchanges) ────────
# CCXT_BRIDGE_URL=http://127.0.0.1:7880
# CCXT_API_KEY=your_key
# CCXT_SECRET=your_secret

# ── Solana ───────────────────────────────────────────────────
# SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ══════════════════════════════════════════════════════════════
# GreedyClaw Brain — AI Agent (set at least ONE LLM provider)
# ══════════════════════════════════════════════════════════════

# ── Anthropic (Claude) — recommended ─────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI (GPT) ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Google (Gemini) ──────────────────────────────────────────
# GOOGLE_API_KEY=AI...
# GOOGLE_MODEL=gemini-2.5-flash

# ── DeepSeek ─────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# ── OpenRouter (200+ models) ─────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# ── Ollama (local, no API key needed) ────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:70b
